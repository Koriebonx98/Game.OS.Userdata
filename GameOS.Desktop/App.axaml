<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GameOS.Desktop.App"
             xmlns:local="using:GameOS.Desktop"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="CardBackground" Color="#16213e"/>
        <SolidColorBrush x:Key="CardBackground2" Color="#0f3460"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#e94560"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#533483"/>
        <SolidColorBrush x:Key="NavBackground" Color="#0d0d1a"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#27ae60"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#e74c3c"/>
        <SolidColorBrush x:Key="MutedText" Color="#8899aa"/>
    </Application.Resources>
</Application>