<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameOS.Desktop.ViewModels"
             xmlns:models="using:GameOS.Desktop.Models"
             x:Class="GameOS.Desktop.Views.ProfileView"
             x:DataType="vm:ProfileViewModel"
             Background="#1a1a2e">

    <ScrollViewer>
        <StackPanel Margin="32,24" Spacing="24" MaxWidth="700">
            <!-- Loading State -->
            <Border Background="#16213e" CornerRadius="10" Padding="40"
                    IsVisible="{Binding IsLoading}">
                <TextBlock Text="Loading profile..." Foreground="#8899aa"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Error State -->
            <Border Background="#3d1a1a" CornerRadius="10" Padding="24"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#e94560"/>
            </Border>

            <!-- Profile Content -->
            <StackPanel Spacing="24" IsVisible="{Binding !IsLoading}">
                <!-- Profile Card -->
                <Border Background="#16213e" CornerRadius="10" Padding="28">
                    <Grid ColumnDefinitions="Auto,*">
                        <!-- Avatar -->
                        <Border Grid.Column="0" Background="#533483" CornerRadius="50"
                                Width="90" Height="90" Margin="0,0,24,0">
                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                       FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{Binding Username}" Foreground="White"
                                       FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Email}" Foreground="#8899aa" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Member since:" Foreground="#8899aa" FontSize="12"/>
                                <TextBlock Text="{Binding MemberSince}" Foreground="#8899aa" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*,*">
                    <Border Grid.Column="0" Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding TotalGames}" FontSize="26" FontWeight="Bold"
                                       Foreground="#e94560" HorizontalAlignment="Center"/>
                            <TextBlock Text="Games" Foreground="#8899aa" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#16213e" CornerRadius="8" Padding="16" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding PlatformCount}" FontSize="26" FontWeight="Bold"
                                       Foreground="#e94560" HorizontalAlignment="Center"/>
                            <TextBlock Text="Platforms" Foreground="#8899aa" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#16213e" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding WishlistCount}" FontSize="26" FontWeight="Bold"
                                       Foreground="#e94560" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wishlisted" Foreground="#8899aa" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Games by Platform -->
                <Border Background="#16213e" CornerRadius="10" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="🎮 Game Library" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <Border Background="#0f3460" CornerRadius="6" Padding="16"
                                IsVisible="{Binding GamesByPlatform.Count, Converter={x:Static vm:IntToBoolConverter.Instance}, ConverterParameter=invert}">
                            <TextBlock Text="No games in library yet." Foreground="#8899aa" HorizontalAlignment="Center"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding GamesByPlatform}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlatformGroupViewModel">
                                    <Border Background="#0f3460" CornerRadius="8" Margin="0,4" Padding="16">
                                        <StackPanel Spacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🎮" FontSize="14"/>
                                                <TextBlock Text="{Binding Platform}" Foreground="White"
                                                           FontWeight="Bold" FontSize="14"/>
                                                <Border Background="#533483" CornerRadius="10" Padding="8,2">
                                                    <TextBlock Text="{Binding Count}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding Games}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:Game">
                                                        <Border Background="#16213e" CornerRadius="4"
                                                                Margin="0,2" Padding="10,6">
                                                            <TextBlock Text="{Binding Title}" Foreground="#cccccc" FontSize="13"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
