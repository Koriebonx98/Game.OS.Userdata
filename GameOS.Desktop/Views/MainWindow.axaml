<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GameOS.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="GameOS.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Game OS"
        Background="#1a1a2e"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="800">

    <DockPanel>
        <!-- Top Navigation Bar -->
        <Border DockPanel.Dock="Top" Background="#0d0d1a" Height="56">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="🎮" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Game OS" FontSize="20" FontWeight="Bold"
                               Foreground="#e94560" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav Links -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="4">
                    <Button Command="{Binding NavigateHomeCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Padding="12,8" CornerRadius="6"
                            Cursor="Hand">Home</Button>
                    <Button Command="{Binding NavigateGamesCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Padding="12,8" CornerRadius="6"
                            Cursor="Hand">Browse Games</Button>
                    <Button Command="{Binding NavigateFriendsCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Padding="12,8" CornerRadius="6"
                            Cursor="Hand">Friends</Button>
                    <!-- Inbox with badge -->
                    <Grid>
                        <Button Command="{Binding NavigateInboxCommand}"
                                Background="Transparent" Foreground="White"
                                BorderThickness="0" Padding="12,8" CornerRadius="6"
                                Cursor="Hand">Inbox</Button>
                        <Border IsVisible="{Binding InboxCount, Converter={x:Static vm:IntToBoolConverter.Instance}}"
                                Background="#e94560" CornerRadius="8" Padding="4,1"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,2,2,0">
                            <TextBlock Text="{Binding InboxCount}" FontSize="10"
                                       Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <Button Command="{Binding NavigateAccountCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Padding="12,8" CornerRadius="6"
                            Cursor="Hand">Account</Button>
                </StackPanel>

                <!-- Auth section -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <!-- Logged out -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding !IsLoggedIn}">
                        <Button Command="{Binding NavigateLoginCommand}"
                                Background="Transparent" Foreground="#8899aa"
                                BorderThickness="1" BorderBrush="#533483"
                                Padding="12,6" CornerRadius="6" Cursor="Hand">Sign In</Button>
                        <Button Command="{Binding NavigateSignupCommand}"
                                Background="#e94560" Foreground="White"
                                BorderThickness="0" Padding="12,6" CornerRadius="6"
                                Cursor="Hand">Get Started</Button>
                    </StackPanel>
                    <!-- Logged in -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsLoggedIn}">
                        <TextBlock Text="{Binding CurrentUsername}" Foreground="#8899aa"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <Button Command="{Binding LogoutCommand}"
                                Background="#533483" Foreground="White"
                                BorderThickness="0" Padding="12,6" CornerRadius="6"
                                Cursor="Hand">Logout</Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Background="#1a1a2e" HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>
        </ScrollViewer>
    </DockPanel>
</Window>
