<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Steam Big Picture inspired shell -->
    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-ps5-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="Window.main-window-shell">
        <Setter Property="Background" Value="#0b111b"/>
    </Style>
    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#0b111b"/>
    </Style>
    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#0a1019"/>
    </Style>
    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0b111b" Offset="0"/>
                    <GradientStop Color="#121f31" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.nav-sidebar">
        <Setter Property="Background" Value="#101a28"/>
    </Style>
    <Style Selector="Border.nav-logo-area">
        <Setter Property="Background" Value="#1b4e80"/>
    </Style>
    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#1b4e80"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="Foreground" Value="#8ea8c3"/>
    </Style>
    <Style Selector="Border.stat-tile">
        <Setter Property="Background" Value="#111d2d"/>
        <Setter Property="BorderBrush" Value="#2a4f73"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.featured-hero-banner">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1b3655" Offset="0"/>
                    <GradientStop Color="#0f2238" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#2a4f73"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.game-card">
        <Setter Property="Background" Value="#111d2d"/>
        <Setter Property="BorderBrush" Value="#2a4f73"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.game-playtime-meta">
        <Setter Property="Foreground" Value="#66c0f4"/>
    </Style>
    <Style Selector="Border.game-platform-pill">
        <Setter Property="Background" Value="#1b4e80"/>
    </Style>

    <Style Selector="Button.btn-primary">
        <Setter Property="Background" Value="#1b4e80"/>
    </Style>
    <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#24639f"/>
    </Style>
    <Style Selector="Button.btn-secondary">
        <Setter Property="BorderBrush" Value="#2a4f73"/>
        <Setter Property="Foreground" Value="#c7d5e0"/>
    </Style>
    <Style Selector="Button.btn-secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#18283b"/>
    </Style>
</Styles>
