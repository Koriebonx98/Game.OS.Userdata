<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nintendo Switch inspired shell -->
    <Style Selector="Border.dashboard-ps5-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="Window.main-window-shell">
        <Setter Property="Background" Value="#13151a"/>
    </Style>
    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#13151a"/>
    </Style>
    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#181b22"/>
    </Style>
    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background" Value="#13151a"/>
    </Style>

    <Style Selector="Border.nav-sidebar">
        <Setter Property="Background" Value="#1e222b"/>
    </Style>
    <Style Selector="Border.nav-logo-area">
        <Setter Property="Background" Value="#e60012"/>
    </Style>
    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#e60012"/>
    </Style>

    <!-- Switch dashboard colors (uses PS5 layout structure) -->
    <Style Selector="TextBlock.ps5-header-title">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>
    <Style Selector="TextBlock.ps5-header-media">
        <Setter Property="Foreground" Value="#ff6f7b"/>
    </Style>
    <Style Selector="TextBlock.ps5-card-title">
        <Setter Property="Foreground" Value="#f1f5ff"/>
    </Style>
    <Style Selector="Border.ps5-achievements-panel">
        <Setter Property="Background" Value="#1f2430"/>
        <Setter Property="BorderBrush" Value="#e60012"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.ps5-status-tile">
        <Setter Property="Background" Value="#1f2430"/>
        <Setter Property="BorderBrush" Value="#e60012"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.ps5-status-value">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>
    <Style Selector="TextBlock.ps5-status-label">
        <Setter Property="Foreground" Value="#bfc7d8"/>
    </Style>

    <Style Selector="Button.ps5-game-card-btn:focus /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="#00c3e3"/>
    </Style>
    <Style Selector="Button.btn-primary">
        <Setter Property="Background" Value="#e60012"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#ff2638"/>
    </Style>
    <Style Selector="Button.btn-secondary">
        <Setter Property="BorderBrush" Value="#e60012"/>
        <Setter Property="Foreground" Value="#f1f5ff"/>
    </Style>
    <Style Selector="Button.btn-secondary.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#e60012"/>
        <Setter Property="BorderBrush" Value="#00c3e3"/>
    </Style>
</Styles>
