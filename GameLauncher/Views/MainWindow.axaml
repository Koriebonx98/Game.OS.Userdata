<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GameLauncher.ViewModels"
        xmlns:views="using:GameLauncher.Views"
        x:Class="GameLauncher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Game.OS Launcher"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="#0d1117"
        Icon="/Assets/avalonia-logo.ico">

    <Grid>
        <!-- ══════════ LOGIN OVERLAY ══════════ -->
        <Border IsVisible="{Binding ShowLogin}">
            <views:LoginView DataContext="{Binding LoginVm}"/>
        </Border>

        <!-- ══════════ MAIN SHELL ══════════ -->
        <Grid IsVisible="{Binding ShowMain}" ColumnDefinitions="220,*">

            <!-- Left sidebar -->
            <Border Grid.Column="0" Classes="nav-sidebar">
                <DockPanel>

                    <!-- Logo -->
                    <Border DockPanel.Dock="Top" Classes="nav-logo-area">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="White">
                                <TextBlock Text="G" FontSize="18" FontWeight="Bold"
                                           Foreground="#0ea5e9"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Game.OS" Classes="nav-logo-text"/>
                        </StackPanel>
                    </Border>

                    <!-- Sign out -->
                    <Button DockPanel.Dock="Bottom"
                            Classes="nav-item"
                            HorizontalAlignment="Stretch"
                            Command="{Binding SignOutCommand}"
                            Margin="8,0,8,16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⏻" FontSize="16"/>
                            <TextBlock Text="Sign Out"/>
                        </StackPanel>
                    </Button>

                    <Rectangle DockPanel.Dock="Bottom" Height="1"
                               Fill="#21262d" Margin="16,0"/>

                    <!-- Nav links -->
                    <StackPanel Margin="0,16,0,0" Spacing="2">

                        <Button Classes="nav-item"
                                Classes.active="{Binding IsHome}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⌂" FontSize="16"/>
                                <TextBlock Text="Home"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Classes.active="{Binding IsLibrary}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="library">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🎮" FontSize="16"/>
                                <TextBlock Text="My Library"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Classes.active="{Binding IsStore}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="store">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🛒" FontSize="16"/>
                                <TextBlock Text="Games Store"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Classes.active="{Binding IsFriends}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="friends">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="👥" FontSize="16"/>
                                <TextBlock Text="Friends"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Classes.active="{Binding IsProfile}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="profile">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="👤" FontSize="16"/>
                                <TextBlock Text="Profile"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content area -->
            <Border Grid.Column="1" Background="#0d1117">
                <Panel>
                    <!-- Main page views -->
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding !ShowDetail}">
                        <Panel>
                            <Border IsVisible="{Binding IsHome}">
                                <views:DashboardView DataContext="{Binding DashboardVm}"/>
                            </Border>
                            <Border IsVisible="{Binding IsLibrary}">
                                <views:LibraryView DataContext="{Binding LibraryVm}"/>
                            </Border>
                            <Border IsVisible="{Binding IsStore}">
                                <views:StoreView DataContext="{Binding StoreVm}"/>
                            </Border>
                            <Border IsVisible="{Binding IsFriends}">
                                <views:FriendsView DataContext="{Binding FriendsVm}"/>
                            </Border>
                            <Border IsVisible="{Binding IsProfile}">
                                <views:ProfileView DataContext="{Binding ProfileVm}"/>
                            </Border>
                        </Panel>
                    </ScrollViewer>

                    <!-- Game detail overlay -->
                    <Border IsVisible="{Binding ShowDetail}" Background="#0d1117">
                        <views:GameDetailView DataContext="{Binding DetailVm}"/>
                    </Border>

                    <!-- Friend profile overlay -->
                    <Border IsVisible="{Binding ShowFriendProfile}" Background="#0d1117">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Back bar -->
                            <Border Grid.Row="0" Background="#161b22" Padding="20,14">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Button Grid.Column="0"
                                            Classes="btn-secondary"
                                            Padding="14,8"
                                            Command="{Binding CloseFriendProfileCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="←" FontSize="16" VerticalAlignment="Center"/>
                                            <TextBlock Text="Back" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ViewingFriendName}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#8b949e"
                                               VerticalAlignment="Center"
                                               Margin="16,0,0,0"/>
                                </Grid>
                            </Border>
                            <!-- Friend profile content -->
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <views:ProfileView DataContext="{Binding FriendProfileVm}"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Panel>
            </Border>

        </Grid>
    </Grid>
</Window>
