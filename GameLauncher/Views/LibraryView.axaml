<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:views="using:GameLauncher.Views"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             Background="#0d1117">

    <StackPanel Margin="32,28,32,28" Spacing="0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="My Library" Classes="page-title"/>
                <TextBlock Text="{Binding TotalGames, StringFormat='{}{0} games in your collection'}"
                           Classes="page-subtitle"/>
            </StackPanel>
            <TextBox Grid.Column="1"
                     Classes="form-input"
                     Text="{Binding SearchText}"
                     Watermark="🔍  Search games…"
                     Width="240" VerticalAlignment="Center"/>
        </Grid>

        <!-- Platform filter chips -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="0,0,0,20">
            <ItemsControl ItemsSource="{Binding Platforms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}"
                                Background="#1f6feb"
                                Foreground="White"
                                CornerRadius="6"
                                Padding="14,7"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Command="{Binding $parent[UserControl].DataContext.SetPlatformCommand}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Game card grid -->
        <ItemsControl ItemsSource="{Binding FilteredGames}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Button Classes="game-card-btn"
                            Command="{Binding $parent[UserControl].DataContext.OpenGameDetailCommand}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <!-- Cover art -->
                            <Border Height="130" CornerRadius="10,10,0,0" ClipToBounds="True">
                                <views:CoverImage
                                    ImageUrl="{Binding CoverUrl}"
                                    FallbackText="{Binding Title}"
                                    FallbackGradient="{Binding CoverGradient}"
                                    SubText="{Binding Platform}"
                                    LetterFontSize="52"
                                    ImageCornerRadius="10,10,0,0"
                                    Height="130"/>
                            </Border>
                            <!-- Info -->
                            <Border Padding="10,10,10,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               Classes="game-card-title"/>
                                    <Border CornerRadius="3" Padding="5,2"
                                            Background="#1f6feb"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding RatingStars}"
                                                   FontSize="11" Foreground="#f1c40f"/>
                                        <TextBlock Text="{Binding Genre}"
                                                   Classes="game-card-meta"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ══ Detected on Drive ══ -->
        <Border IsVisible="{Binding HasLocalGames}"
                Margin="0,32,0,0" Padding="0,0,0,12">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="💿" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Detected on Drive"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <Border CornerRadius="10" Padding="8,3" Background="#238636"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding LocalGames.Count}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding LocalGames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:LocalGame">
                            <Button Classes="game-card-btn"
                                    Width="170" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.OpenLocalGameDetailCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Drive art -->
                                    <Border Height="100" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#0d2137" Offset="0"/>
                                                <GradientStop Color="#163d5e" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Text="💿" FontSize="32"
                                                       HorizontalAlignment="Center"/>
                                            <!-- Drive count badge -->
                                            <Border CornerRadius="8" Padding="6,2"
                                                    Background="#238636"
                                                    HorizontalAlignment="Center"
                                                    IsVisible="{Binding HasMultipleDrives}">
                                                <TextBlock Text="{Binding DriveCountLabel}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="#1a5e34" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ExecutableType, StringFormat='{}• {0}'}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#3fb950"/>
                                            </Border>
                                            <TextBlock Text="{Binding DriveRoot}"
                                                       FontSize="10" Foreground="#8b949e"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ══ Ready to Install ══ -->
        <Border IsVisible="{Binding HasRepacks}"
                Margin="0,32,0,0" Padding="0,0,0,12">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="📦" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Ready to Install"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <Border CornerRadius="10" Padding="8,3" Background="#9e6a03"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding ReadyToInstall.Count}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding ReadyToInstall}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:LocalRepack">
                            <Button Classes="game-card-btn"
                                    Width="200" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.OpenRepackDetailCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Repack art -->
                                    <Border Height="90" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#2d1b00" Offset="0"/>
                                                <GradientStop Color="#5c3800" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="📦" FontSize="36"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="#5c3800" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding FileType, StringFormat='{}.{0}'}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#e3b341"/>
                                                </Border>
                                                <TextBlock Text="{Binding SizeLabel}"
                                                           FontSize="10" Foreground="#8b949e"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ══ ROMs ══ -->
        <Border IsVisible="{Binding HasRoms}"
                Margin="0,32,0,0" Padding="0,0,0,12">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🕹" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="ROMs"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <Border CornerRadius="10" Padding="8,3" Background="#1f3a6e"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding LocalRoms.Count}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding LocalRoms}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:LocalRom">
                            <Border Classes="game-card" Width="170" Margin="0,0,10,10">
                                <StackPanel>
                                    <!-- ROM art -->
                                    <Border Height="100" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#0d1f3c" Offset="0"/>
                                                <GradientStop Color="#1a3264" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="🕹" FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="#1f3a6e" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Platform}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#58a6ff"/>
                                                </Border>
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="#21262d" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding FileType, StringFormat='{}.{0}'}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#8b949e"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SizeLabel}"
                                                       FontSize="10" Foreground="#8b949e"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
