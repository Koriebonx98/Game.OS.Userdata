<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             x:Class="GameLauncher.Views.MediaView"
             x:DataType="vm:MediaViewModel">

    <Panel>
        <!-- Main scrollable content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding !IsVlcPlayerOpen}">
            <StackPanel Margin="32,28,32,28" Spacing="24">

                <!-- Page title -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Media" Classes="page-title"/>
                        <TextBlock Text="Your movies, TV shows, and music library."
                                   Classes="page-subtitle" Margin="0,-20,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="btn-secondary"
                                Command="{Binding ScanMediaFoldersCommand}"
                                Padding="12,8">
                            🔄  Refresh
                        </Button>
                        <Button Classes="btn-primary"
                                Command="{Binding PlayLocalVideoCommand}"
                                Padding="14,8">
                            🎬  Play File…
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ── Movies ──────────────────────────────────────────────── -->
                <TextBlock Text="🎬  Movies" Classes="section-header"/>

                <!-- Movie cards grid -->
                <ItemsControl ItemsSource="{Binding MovieFiles}"
                              IsVisible="{Binding HasMovies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaFileCardVm">
                            <Button Classes="game-card-btn"
                                    Width="170" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.PlayMediaFileCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Icon area -->
                                    <Border Height="110" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#0d1b2a" Offset="0"/>
                                                <GradientStop Color="#1a3a6e" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeEmoji}"
                                                   FontSize="42"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="{Binding BadgeBackground}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding BadgeForeground}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for Movies -->
                <Border Classes="xb360-metro-tile" CornerRadius="10" Padding="20,16"
                        IsVisible="{Binding !HasMovies}">
                    <TextBlock Text="No movies found in your Videos folder."
                               FontSize="13" Foreground="#484f58"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- ── TV Shows ─────────────────────────────────────────────── -->
                <TextBlock Text="📺  TV Shows" Classes="section-header"/>

                <!-- TV Show cards grid -->
                <ItemsControl ItemsSource="{Binding TvShowFiles}"
                              IsVisible="{Binding HasTvShows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaFileCardVm">
                            <Button Classes="game-card-btn"
                                    Width="170" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.PlayMediaFileCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Icon area -->
                                    <Border Height="110" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#0d1f17" Offset="0"/>
                                                <GradientStop Color="#1a4a2e" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeEmoji}"
                                                   FontSize="42"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="{Binding BadgeBackground}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding BadgeForeground}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for TV Shows -->
                <Border Classes="xb360-metro-tile" CornerRadius="10" Padding="20,16"
                        IsVisible="{Binding !HasTvShows}">
                    <TextBlock Text="No TV shows found in Videos\TV Shows."
                               FontSize="13" Foreground="#484f58"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- ── Music ───────────────────────────────────────────────── -->
                <TextBlock Text="🎵  Music" Classes="section-header"/>

                <!-- Music cards grid -->
                <ItemsControl ItemsSource="{Binding MusicFiles}"
                              IsVisible="{Binding HasMusic}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MediaFileCardVm">
                            <Button Classes="game-card-btn"
                                    Width="170" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.PlayMediaFileCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Icon area -->
                                    <Border Height="110" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="#1a1000" Offset="0"/>
                                                <GradientStop Color="#3d2a0a" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeEmoji}"
                                                   FontSize="42"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border CornerRadius="3" Padding="5,2"
                                                    Background="{Binding BadgeBackground}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding BadgeForeground}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for Music -->
                <Border Classes="xb360-metro-tile" CornerRadius="10" Padding="20,16"
                        IsVisible="{Binding !HasMusic}">
                    <TextBlock Text="No music found in your Music folder."
                               FontSize="13" Foreground="#484f58"
                               HorizontalAlignment="Center"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- VLC player overlay (shown when IsVlcPlayerOpen) -->
        <Border Background="#0d1117"
                IsVisible="{Binding IsVlcPlayerOpen}"
                ZIndex="50">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Top bar -->
                <Border Grid.Row="0" Background="#161b22" Padding="16,10">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0"
                                Classes="btn-secondary"
                                Padding="10,6"
                                Command="{Binding CloseVlcPlayerCommand}">
                            ✕  Close
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VlcMediaPath}"
                                   FontSize="13"
                                   Foreground="#c9d1d9"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2"
                                   Text="🎬 VLC Player"
                                   FontSize="12"
                                   Foreground="#8b949e"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Video surface -->
                <vlc:VideoView Grid.Row="1"
                               x:Name="VlcOverlayVideoView"/>

                <!-- Bottom hint -->
                <Border Grid.Row="2" Background="#161b22" Padding="16,8">
                    <TextBlock Text="Powered by VLC · press Close to stop playback"
                               FontSize="11"
                               Foreground="#484f58"
                               HorizontalAlignment="Center"/>
                </Border>

            </Grid>
        </Border>

    </Panel>
</UserControl>
