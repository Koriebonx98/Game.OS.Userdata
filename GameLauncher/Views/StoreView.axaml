<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:views="using:GameLauncher.Views"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.StoreView"
             x:DataType="vm:StoreViewModel"
             Background="#0d1117">

    <StackPanel Margin="32,28,32,28" Spacing="0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Games Store" Classes="page-title"
                           IsVisible="{Binding IsGamesTab}"/>
                <TextBlock Text="App Store" Classes="page-title"
                           IsVisible="{Binding IsAppStoreTab}"/>
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsGamesTab}">
                    <TextBlock Text="Discover and add games to your library"
                               Classes="page-subtitle"/>
                    <TextBlock Text="·" Classes="page-subtitle"/>
                    <TextBlock Text="{Binding CatalogCountLabel}"
                               Classes="page-subtitle"
                               Foreground="#1f6feb"
                               IsVisible="{Binding HasCatalogCount}"/>
                </StackPanel>
                <TextBlock Text="Browse and download apps, emulators, and tools"
                           Classes="page-subtitle"
                           IsVisible="{Binding IsAppStoreTab}"/>
            </StackPanel>
            <TextBox Grid.Column="1"
                     Classes="form-input"
                     Text="{Binding SearchText}"
                     Watermark="🔍  Search store…"
                     Width="240" VerticalAlignment="Center"
                     IsVisible="{Binding IsGamesTab}"/>
            <TextBox Grid.Column="1"
                     Classes="form-input"
                     Text="{Binding AppStoreSearchText}"
                     Watermark="🔍  Search apps…"
                     Width="240" VerticalAlignment="Center"
                     IsVisible="{Binding IsAppStoreTab}"/>
        </Grid>

        <!-- ── Tab selector ── -->
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,20">
            <Button Padding="18,9" CornerRadius="8" BorderThickness="0"
                    Background="#1f6feb"
                    Command="{Binding SwitchToGamesTabCommand}"
                    IsVisible="{Binding IsGamesTab}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🎮" FontSize="14"/>
                    <TextBlock Text="Games Store" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Button>
            <Button Padding="18,9" CornerRadius="8" BorderThickness="0"
                    Background="#21262d"
                    Command="{Binding SwitchToGamesTabCommand}"
                    IsVisible="{Binding IsAppStoreTab}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🎮" FontSize="14"/>
                    <TextBlock Text="Games Store" FontSize="13" FontWeight="SemiBold" Foreground="#8b949e"/>
                </StackPanel>
            </Button>
            <Button Padding="18,9" CornerRadius="8" BorderThickness="0"
                    Background="#21262d"
                    Command="{Binding SwitchToAppStoreTabCommand}"
                    IsVisible="{Binding IsGamesTab}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📦" FontSize="14"/>
                    <TextBlock Text="App Store" FontSize="13" FontWeight="SemiBold" Foreground="#8b949e"/>
                </StackPanel>
            </Button>
            <Button Padding="18,9" CornerRadius="8" BorderThickness="0"
                    Background="#1f6feb"
                    Command="{Binding SwitchToAppStoreTabCommand}"
                    IsVisible="{Binding IsAppStoreTab}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📦" FontSize="14"/>
                    <TextBlock Text="App Store" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             GAMES STORE TAB
        ══════════════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsGamesTab}" Spacing="0">

        <!-- ══ ADMIN PANEL ══ (only visible to Admin.GameOS account) -->
        <Border IsVisible="{Binding IsAdmin}"
                Background="#1a0c2e" CornerRadius="10" Padding="16,14"
                Margin="0,0,0,20">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="🛡️  Admin — Catalog Management"
                               FontSize="15" FontWeight="Bold" Foreground="#c084fc"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Classes="btn-secondary"
                            Padding="12,6"
                            Command="{Binding AdminToggleFormCommand}">
                        <Panel>
                            <TextBlock Text="+ Add Game" IsVisible="{Binding !ShowAdminForm}"/>
                            <TextBlock Text="✕ Cancel"   IsVisible="{Binding ShowAdminForm}"/>
                        </Panel>
                    </Button>
                </Grid>

                <!-- Add-game form (shown when ShowAdminForm = true) -->
                <StackPanel IsVisible="{Binding ShowAdminForm}" Spacing="10">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Title *" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminTitle}"
                                     Watermark="Game title"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Platform *" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminPlatform}"
                                     Watermark="PC / Switch / PS5 …"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,8,0">
                            <TextBlock Text="Genre" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminGenre}"
                                     Watermark="RPG / FPS / Action …"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,0,0">
                            <TextBlock Text="Price" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminPrice}"
                                     Watermark="£49.99 / Free"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,8,8,0">
                            <TextBlock Text="Rating (0–10)" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminRating}"
                                     Watermark="8.0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                            <TextBlock Text="Cover URL" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminCoverUrl}"
                                     Watermark="https://…"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="Description" Classes="form-label"/>
                            <TextBox Classes="form-input" Text="{Binding AdminDescription}"
                                     Watermark="Short description…"
                                     AcceptsReturn="False"/>
                        </StackPanel>
                    </Grid>
                    <Button Classes="btn-primary" HorizontalAlignment="Left" Padding="20,8"
                            Command="{Binding AdminAddCatalogGameCommand}">
                        ✓  Add to Catalog
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status message -->
        <Border Background="#0d3d1a" CornerRadius="6" Padding="14,10"
                Margin="0,0,0,16"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#3fb950" FontSize="13"/>
        </Border>

        <!-- Loading indicator -->
        <Border Background="#161b22" CornerRadius="6" Padding="14,10"
                Margin="0,0,0,16"
                IsVisible="{Binding IsLoading}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⏳" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LoadingMessage}"
                           Foreground="#8b949e" FontSize="13"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Featured banner -->
        <TextBlock Text="⭐  Featured &amp; New Releases"
                   Classes="section-header" Margin="0,0,0,12"
                   IsVisible="{Binding HasFeatured}"/>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="0,0,0,28"
                      IsVisible="{Binding HasFeatured}">
            <ItemsControl ItemsSource="{Binding Featured}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:StoreGame">
                        <Border Width="240" CornerRadius="12" Cursor="Hand"
                                Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#0a1628" Offset="0"/>
                                    <GradientStop Color="#1a3a6e" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Border Height="140" CornerRadius="12,12,0,0" ClipToBounds="True">
                                    <views:CoverImage
                                        ImageUrl="{Binding CoverUrl}"
                                        FallbackText="{Binding Title}"
                                        FallbackGradient="{Binding CoverGradient}"
                                        SubText="{Binding Genre}"
                                        LetterFontSize="64"
                                        ImageCornerRadius="12,12,0,0"
                                        Height="140"/>
                                </Border>
                                <Border Padding="14,12">
                                    <StackPanel Spacing="6">
                                        <Border Background="#1f6feb" CornerRadius="3"
                                                Padding="6,2" HorizontalAlignment="Left">
                                            <TextBlock Text="NEW" FontSize="10"
                                                       FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Genre}"
                                                   FontSize="12" Foreground="#8b949e"/>
                                        <TextBlock Text="{Binding RatingStars}"
                                                   FontSize="12" Foreground="#f1c40f"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Button Grid.Column="0"
                                                    Classes="btn-success"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding $parent[UserControl].DataContext.AddGameCommand}"
                                                    CommandParameter="{Binding}">
                                                + Add
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Classes="btn-secondary"
                                                    Padding="10,8"
                                                    ToolTip.Tip="View Details"
                                                    Command="{Binding $parent[UserControl].DataContext.OpenGameDetailCommand}"
                                                    CommandParameter="{Binding}">
                                                ···
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Platform selector + Genre filter + heading -->
        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,6">
            <TextBlock Grid.Column="0"
                       Text="Browse Games" Classes="section-header"
                       VerticalAlignment="Center" Margin="0"/>
            <Button Grid.Column="1" Classes="btn-secondary" Padding="10,6"
                    Margin="0,0,8,0"
                    ToolTip.Tip="Force re-fetch games for this platform"
                    Command="{Binding RefreshPlatformCommand}"
                    IsVisible="{Binding SelectedPlatform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                🔄
            </Button>
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Platforms}"
                      SelectedItem="{Binding SelectedPlatform}"
                      Width="150" Margin="0,0,8,0"
                      ToolTip.Tip="Filter by platform"/>
            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding FilterGenre}"
                      Width="180"/>
        </Grid>

        <!-- Games count label -->
        <TextBlock Text="{Binding BrowseCountLabel}"
                   FontSize="12" Foreground="#8b949e"
                   Margin="0,0,0,14"
                   IsVisible="{Binding BrowseCountLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- Full catalogue -->
        <ItemsControl ItemsSource="{Binding FilteredStore}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:StoreGame">
                    <Button Classes="store-card-btn"
                            Command="{Binding $parent[UserControl].DataContext.OpenGameDetailCommand}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <Border Height="120" CornerRadius="10,10,0,0" ClipToBounds="True">
                                <views:CoverImage
                                    ImageUrl="{Binding CoverUrl}"
                                    FallbackText="{Binding Title}"
                                    FallbackGradient="{Binding CoverGradient}"
                                    SubText="{Binding Genre}"
                                    LetterFontSize="56"
                                    ImageCornerRadius="10,10,0,0"
                                    Height="120"/>
                            </Border>
                            <Border Padding="12,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" TextWrapping="Wrap"
                                               MaxLines="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding Genre}"
                                                   FontSize="11" Foreground="#8b949e"/>
                                        <TextBlock Text="·" FontSize="11" Foreground="#8b949e"/>
                                        <TextBlock Text="{Binding ReleaseYear}"
                                                   FontSize="11" Foreground="#8b949e"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RatingStars}"
                                               FontSize="11" Foreground="#f1c40f"/>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button Classes="btn-success"
                                                    Padding="8,5"
                                                    Command="{Binding $parent[UserControl].DataContext.AddGameCommand}"
                                                    CommandParameter="{Binding}">
                                                +
                                            </Button>
                                            <!-- Admin delete button -->
                                            <Button Classes="btn-secondary"
                                                    Padding="8,5"
                                                    Foreground="#f85149"
                                                    ToolTip.Tip="Admin: Remove from catalog"
                                                    IsVisible="{Binding $parent[UserControl].DataContext.IsAdmin}"
                                                    Command="{Binding $parent[UserControl].DataContext.AdminDeleteCatalogGameCommand}"
                                                    CommandParameter="{Binding}">
                                                🗑
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Load More button — shown when there are more games beyond the current display limit -->
        <Button Classes="btn-secondary"
                Content="⬇  Load More Games"
                HorizontalAlignment="Center"
                Margin="0,16,0,8"
                Padding="24,10"
                IsVisible="{Binding HasMoreGames}"
                Command="{Binding LoadMoreCommand}"/>

        </StackPanel>
        <!-- end IsGamesTab -->

        <!-- ══════════════════════════════════════════════════════════
             APP STORE TAB
        ══════════════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding IsAppStoreTab}" Spacing="0">

            <!-- Genre filter -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Grid.Column="0" Text="Browse Apps"
                           Classes="section-header" VerticalAlignment="Center" Margin="0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AppStoreGenres}"
                          SelectedItem="{Binding AppStoreGenreFilter}"
                          Width="180"/>
            </Grid>

            <!-- App cards -->
            <ItemsControl ItemsSource="{Binding FilteredAppStoreEntries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AppStoreEntry">
                        <Border Background="#161b22" CornerRadius="10"
                                Width="200" Margin="0,0,12,12">
                            <StackPanel>
                                <!-- Cover image -->
                                <Border Height="120" CornerRadius="10,10,0,0" ClipToBounds="True">
                                    <views:CoverImage
                                        ImageUrl="{Binding RawImageUrl}"
                                        FallbackText="{Binding Name}"
                                        FallbackGradient="#1e1b4b,#312e81"
                                        SubText="{Binding Genre}"
                                        LetterFontSize="48"
                                        ImageCornerRadius="10,10,0,0"
                                        Height="120"/>
                                </Border>
                                <!-- Info -->
                                <Border Padding="12,10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White" TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Border CornerRadius="3" Padding="5,2" Background="#1f6feb">
                                                <TextBlock Text="{Binding Genre}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="11" Foreground="#8b949e"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding EmulatorPlatforms}"
                                                   FontSize="10" Foreground="#3fb950"
                                                   IsVisible="{Binding EmulatorPlatforms, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Classes="btn-primary"
                                                Padding="8,5" Margin="0,4,0,0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Command="{Binding $parent[UserControl].DataContext.OpenAppUrlCommand}"
                                                CommandParameter="{Binding}">
                                            📥 Get App
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Loading indicator for App Store -->
            <TextBlock Text="Loading apps…"
                       Foreground="#8b949e" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,24,0,0"
                       IsVisible="{Binding !FilteredAppStoreEntries.Count}"/>

        </StackPanel>
        <!-- end IsAppStoreTab -->

    </StackPanel>
</UserControl>
