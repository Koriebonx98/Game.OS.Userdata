<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             x:Class="GameLauncher.Views.FriendsView"
             x:DataType="vm:FriendsViewModel"
             Background="#0d1117">

    <Grid RowDefinitions="Auto,Auto,*" Margin="24,24,24,0">

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="👥 Friends"
                       FontSize="26" FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Foreground="#8b949e" FontSize="14" Margin="0,4,0,0">
                <Run Text="{Binding FriendCount}"/>
                <Run Text=" friends"/>
            </TextBlock>
        </StackPanel>

        <!-- Search / Add friend bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <Border Background="#161b22" CornerRadius="8" BorderBrush="#30363d" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                               Foreground="#8b949e" Margin="12,0,8,0" FontSize="14"/>
                    <TextBox  Grid.Column="1"
                              Watermark="Search or add a friend by username…"
                              Text="{Binding SearchQuery}"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="White"
                              CaretBrush="White"
                              Padding="0,10,12,10"
                              FontSize="14"/>
                </Grid>
            </Border>
            <Button Grid.Column="1" Content="➕ Add Friend"
                    Classes="btn-primary"
                    Margin="10,0,0,0"
                    Padding="16,0"/>
        </Grid>

        <!-- Friends list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6">
                <!-- Online section header -->
                <TextBlock Text="ONLINE"
                           Foreground="#8b949e" FontSize="11" FontWeight="Bold"
                           LetterSpacing="1" Margin="0,0,0,4"/>

                <ItemsControl ItemsSource="{Binding Friends}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FriendItem">
                            <Border Background="#161b22"
                                    CornerRadius="10"
                                    BorderBrush="#21262d"
                                    BorderThickness="1"
                                    Padding="16,12"
                                    Margin="0,0,0,6">
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <!-- Avatar circle -->
                                    <Border Grid.Column="0"
                                            Width="42" Height="42"
                                            CornerRadius="21"
                                            Background="#1f6feb"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Initial}"
                                                   Foreground="White"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Name + status -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Username}"
                                                       Foreground="White"
                                                       FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding StatusDot}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       Foreground="#8b949e" FontSize="12"/>
                                            <TextBlock Text="·" Foreground="#8b949e" FontSize="12"/>
                                            <TextBlock Text="{Binding SharedGames}"
                                                       Foreground="#58a6ff" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Button Content="👤 Profile"
                                                Classes="btn-secondary"
                                                Padding="12,6"
                                                FontSize="12"/>
                                        <Button Content="💬 Message"
                                                Classes="btn-secondary"
                                                Padding="12,6"
                                                FontSize="12"/>
                                        <Button Content="Remove"
                                                Classes="btn-danger"
                                                Padding="12,6"
                                                FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <StackPanel IsVisible="{Binding !FriendCount}"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0"
                            Spacing="8">
                    <TextBlock Text="👥" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="No friends yet"
                               Foreground="#8b949e" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Search above to add someone!"
                               Foreground="#8b949e" FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
