<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.FriendsView"
             x:DataType="vm:FriendsViewModel"
             Background="#0d1117">

    <Grid RowDefinitions="*,Auto">

    <!-- ── Friends list (scrollable) ── -->
    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,28" Spacing="0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Friends" Classes="page-title"/>
                <TextBlock Classes="page-subtitle">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} online · {1} total">
                            <Binding Path="OnlineCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="1" Classes="btn-primary"
                    VerticalAlignment="Center" Padding="16,10">
                + Add Friend
            </Button>
        </Grid>

        <!-- Loading indicator -->
        <TextBlock Text="Loading friends…"
                   Foreground="#8b949e" FontSize="13" Margin="0,0,0,16"
                   IsVisible="{Binding IsLoading}"/>

        <!-- Error message -->
        <Border Background="#3d1a1a" CornerRadius="6" Padding="14,10"
                Margin="0,0,0,16"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#f85149" FontSize="13"/>
        </Border>

        <!-- Pending Requests -->
        <StackPanel IsVisible="{Binding PendingRequests.Count}" Margin="0,0,0,24">
            <TextBlock Text="Friend Requests" Classes="section-header"/>
            <ItemsControl ItemsSource="{Binding PendingRequests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendRequestDisplay">
                        <Border Background="#161b22" CornerRadius="10"
                                Padding="16,12" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="48,*,Auto,Auto">
                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="40" Height="40"
                                        CornerRadius="20" Background="#1f6feb">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0" Spacing="2">
                                    <TextBlock Text="{Binding FromUsername}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock FontSize="11" Foreground="#8b949e">
                                        <Run Text="Sent "/>
                                        <Run Text="{Binding SentAgo}"/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Accept -->
                                <Button Grid.Column="2" Classes="btn-success"
                                        Padding="14,7" Margin="0,0,8,0">
                                    ✓ Accept
                                </Button>
                                <!-- Decline -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="14,7">
                                    ✕ Decline
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Online Friends -->
        <StackPanel IsVisible="{Binding OnlineFriends.Count}" Margin="0,0,0,24">
            <TextBlock Classes="section-header">
                <Run Text="🟢  Online — "/>
                <Run Text="{Binding OnlineCount}"/>
            </TextBlock>
            <ItemsControl ItemsSource="{Binding OnlineFriends}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendEntry">
                        <Border Background="#161b22" CornerRadius="10"
                                Padding="16,12" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="48,*,Auto,Auto">
                                <!-- Avatar with status dot -->
                                <Panel Grid.Column="0" Width="40" Height="40">
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#1f6feb">
                                        <TextBlock Text="{Binding AvatarInitial}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Status dot -->
                                    <Border Width="13" Height="13" CornerRadius="7"
                                            Background="#3fb950"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsVisible="{Binding IsOnline}"/>
                                    <Border Width="13" Height="13" CornerRadius="7"
                                            Background="#f1c40f"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsVisible="{Binding IsAway}"/>
                                </Panel>
                                <!-- Friend info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0" Spacing="2">
                                    <TextBlock Text="{Binding Username}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="12" Foreground="#3fb950"
                                                   IsVisible="{Binding IsOnline}"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="12" Foreground="#f1c40f"
                                                   IsVisible="{Binding IsAway}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- View Profile button -->
                                <Button Grid.Column="2" Classes="btn-secondary"
                                        Padding="10,7" VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Command="{Binding $parent[UserControl].DataContext.ViewFriendProfileCommand}"
                                        CommandParameter="{Binding Username}">
                                    👤 Profile
                                </Button>
                                <!-- Message button -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="12,7" VerticalAlignment="Center"
                                        Command="{Binding $parent[UserControl].DataContext.OpenConversationCommand}"
                                        CommandParameter="{Binding Username}">
                                    💬 Message
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Offline Friends -->
        <StackPanel IsVisible="{Binding OfflineFriends.Count}">
            <TextBlock Text="⚫  Offline" Classes="section-header"/>
            <ItemsControl ItemsSource="{Binding OfflineFriends}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendEntry">
                        <Border Background="#161b22" CornerRadius="10"
                                Padding="16,12" Margin="0,0,0,8"
                                Opacity="0.7">
                            <Grid ColumnDefinitions="48,*,Auto,Auto">
                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="40" Height="40"
                                        CornerRadius="20" Background="#21262d">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#8b949e"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Friend info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0" Spacing="2">
                                    <TextBlock Text="{Binding Username}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#c9d1d9"/>
                                    <TextBlock FontSize="12" Foreground="#8b949e">
                                        <Run Text="Last seen "/>
                                        <Run Text="{Binding LastSeen}"/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- View Profile button -->
                                <Button Grid.Column="2" Classes="btn-secondary"
                                        Padding="10,7" VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Command="{Binding $parent[UserControl].DataContext.ViewFriendProfileCommand}"
                                        CommandParameter="{Binding Username}">
                                    👤 Profile
                                </Button>
                                <!-- Message button -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="12,7" VerticalAlignment="Center"
                                        Opacity="0.6"
                                        Command="{Binding $parent[UserControl].DataContext.OpenConversationCommand}"
                                        CommandParameter="{Binding Username}">
                                    💬 Message
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Empty state — shown when not loading and no friends found -->
        <TextBlock Text="No friends yet. Add friends to see them here."
                   Foreground="#8b949e" FontSize="13" HorizontalAlignment="Center"
                   Margin="0,32,0,0"
                   IsVisible="{Binding HasNoFriends}"/>

    </StackPanel>
    </ScrollViewer>

    <!-- ── Inline conversation panel ── -->
    <Border Grid.Row="1"
            Background="#161b22"
            BorderBrush="#30363d"
            BorderThickness="0,1,0,0"
            IsVisible="{Binding ShowConversation}">
        <Grid RowDefinitions="Auto,*,Auto" MaxHeight="340">

            <!-- Conversation header -->
            <Border Grid.Row="0" Padding="16,10" Background="#1c2128">
                <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="16"/>
                    <TextBlock Text="{Binding ConversationFriend}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="btn-secondary" Padding="10,6"
                        Command="{Binding CloseConversationCommand}">
                    ✕
                </Button>
                </Grid>
            </Border>

            <!-- Message list -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,8">
                <StackPanel Spacing="8">
                    <!-- Message error -->
                    <TextBlock Text="{Binding MessageError}"
                               Foreground="#f85149" FontSize="12"
                               IsVisible="{Binding MessageError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <!-- No messages yet -->
                    <TextBlock Text="No messages yet. Say hello!"
                               Foreground="#8b949e" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,16,0,0"
                               IsVisible="{Binding !ConversationMessages.Count}"/>
                    <!-- Message bubbles -->
                    <ItemsControl ItemsSource="{Binding ConversationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Message">
                                <Border CornerRadius="10" Padding="10,7"
                                        Margin="0,2">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding From}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#1f6feb"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="13" Foreground="#c9d1d9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Send message input -->
            <Border Grid.Row="2" Padding="12,10" Background="#1c2128">
                <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding NewMessageText}"
                         Watermark="Type a message…"
                         Background="#21262d"
                         Foreground="White"
                         BorderBrush="#30363d"
                         CornerRadius="8"
                         Padding="10,8"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Classes="btn-primary"
                        Padding="16,8"
                        IsEnabled="{Binding !IsSendingMessage}"
                        Command="{Binding SendMessageCommand}">
                    Send ➤
                </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>

    </Grid>
</UserControl>
