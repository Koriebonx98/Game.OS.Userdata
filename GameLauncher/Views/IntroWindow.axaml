<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameLauncher.Views.IntroWindow"
        Title="GameOS"
        Background="Black"
        WindowState="FullScreen"
        SystemDecorations="None"
        CanResize="False"
        Topmost="True"
        ShowInTaskbar="False">

    <!-- Plain black container; platform-specific video host is added in code-behind -->
    <Grid x:Name="VideoContainer" Background="Black" />

</Window>
